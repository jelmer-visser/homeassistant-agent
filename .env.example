# Copy this file to .env and fill in your values.
# Never commit your real .env to version control.

# ── Home Assistant ─────────────────────────────────────────────────────────
# URL of your HA instance (no trailing slash)
HA_BASE_URL=https://homeassistant.versahost.nl

# Long-lived access token from HA → Profile → Long-Lived Access Tokens
HA_TOKEN=your_home_assistant_long_lived_token_here

# ── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_api_key_here

# ── Scheduling ─────────────────────────────────────────────────────────────
# How often to run an analysis cycle (minutes)
AGENT_INTERVAL_MINUTES=30

# How many hours of history to fetch per sensor
HISTORY_HOURS=24

# Max data points per sensor after resampling (30-min buckets over 24h → 48)
MAX_HISTORY_POINTS=48

# ── Sensors config ─────────────────────────────────────────────────────────
SENSORS_CONFIG_PATH=config/sensors.yaml

# ── Delivery ───────────────────────────────────────────────────────────────
# Send results as HA persistent notification
NOTIFY_HA=true

# Enable optional FastAPI web dashboard (requires pip install ha-agent[web])
ENABLE_WEB_UI=false
WEB_UI_PORT=8080

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs

# ── Electricity pricing ────────────────────────────────────────────────────
# "fixed" = use FIXED_DAY_RATE / FIXED_NIGHT_RATE
# "dynamic" = use Nord Pool live price (switch at end of year)
TARIFF_TYPE=fixed
FIXED_DAY_RATE=0.359
FIXED_NIGHT_RATE=0.303

# Nord Pool entity ID (used when TARIFF_TYPE=dynamic)
NORDPOOL_ENTITY_ID=sensor.nordpool_kwh_nl_eur_3_10_021
